{
  "name": "@m-programmation/discord-giveaways",
  "version": "0.1.0",
  "description": "A powerful, extensible Discord giveaways module with fully customizable embeds and complete history tracking.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "discord",
    "discord.js",
    "giveaway",
    "giveaways",
    "bot"
  ],
  "author": "M-PROGRAMMATION",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M-PROGRAMMATION/m-discord-giveaways.git"
  },
  "bugs": {
    "url": "https://github.com/M-PROGRAMMATION/m-discord-giveaways/issues"
  },
  "homepage": "https://github.com/M-PROGRAMMATION/m-discord-giveaways#readme",
  "peerDependencies": {
    "discord.js": "^14.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "discord.js": "^14.16.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^4.1.10"
  }
}
